# ── Person / Business Finder — Environment Variables ──────────────────────
# Copy this file to .env and fill in your keys.
# Tools work without any keys (DuckDuckGo search is free/keyless).
# Add SCRAPER_API_KEY to unlock Whitepages, Spokeo, PeekYou, and other
# bot-protected people-finder directories.

# ScraperAPI — bypasses bot blocks on directory sites (Whitepages, Spokeo, etc.)
# Sign up free at https://www.scraperapi.com — 1,000 free API calls/month
# Standard calls: 1 credit | JS-rendered pages: 5–10 credits
# The tool auto-detects which domains need the proxy; open sites fetch directly.
SCRAPER_API_KEY=your_key_here

# RapidAPI — enables TikTok profile search via API (much more reliable than DDG)
# Get your key at https://rapidapi.com — one key works across all RapidAPI services
# Set RAPIDAPI_TIKTOK_HOST to whichever TikTok API you're subscribed to.
# Supported hosts (pick one from your RapidAPI subscriptions):
#   tiktok-api23.p.rapidapi.com     (recommended — TikTok API by tokcount)
#   tiktok-scraper7.p.rapidapi.com  (TikTok Scraper)
#   tiktok82.p.rapidapi.com         (TikTok API by datauniverse)
RAPIDAPI_KEY=your_key_here
RAPIDAPI_TIKTOK_HOST=tiktok-api23.p.rapidapi.com

# Optional: Hunter.io — email lookup by company domain
# https://hunter.io — 25 free searches/month
# HUNTER_API_KEY=your_key_here
